                self.outputFileName = f"{base}_ray{ext}"
            else:
                filename, _ = QFileDialog.getSaveFileName(self, "Save YAML file", "", "YAML files (*.yml *.yaml)")
                if not filename:
                    return
                else:
                    self.outputFileName = filename

            try:
                save_yaml_file(self.yaml_config, self.outputFileName)
                self.statusBar().showMessage(f"✓ YAML file saved: {self.outputFileName}")
            except Exception as e:
                QMessageBox.critical(self, "Error", f"Error saving: {e}")

        def get_rotations_from_inputs(self):
            """read from GUI all values needed to define two rotations """
            try:
                axes_angles = []
                angle1 = float(self.angle1_input.text())
                axis1 = [float(inp.text()) for inp in self.axe1_inputs]
                axes_angles.append((axis1, angle1))

                angle2 = float(self.angle2_input.text())
                axis2 = [float(inp.text()) for inp in self.axe2_inputs]
                axes_angles.append((axis2, angle2))

                return axes_angles
            except ValueError:
                return [([1, 0, 0], 0), ([0, 1, 0], 0)]

        def on_vector_scale_changed(self, value):
            """Called when vector scale spinbox value changes"""
            self.statusBar().showMessage(f"Vector scale changed to: {value}")
            if self.show_vectors_checkbox.isChecked():
                self.update_mesh()

        def update_mesh(self):
            ''' 3D replot '''
            try:
                axes_angles = self.get_rotations_from_inputs()
                rotated_points = apply_sequential_quaternion_rotations(
                    self.original_points, axes_angles
                )
                mesh = create_pyvista_mesh(rotated_points, self.triangles)

                self.plotter.clear()
                self.plotter.add_mesh(mesh, color="lightblue", show_edges=False, opacity=1.0)
                self.add_bounding_box(self.original_points, axes_angles)
            
            # Add magnetization vectors if available and enabled
                if (self.show_vectors_checkbox.isChecked() and 
                    self.magnetization_data is not None and 
                    self.mesh_object is not None):
                    self.add_magnetization_vectors(axes_angles)
                
            # === GRADUATIONS + NUMÉROTATION X Y Z (ROBUSTE) ===
                self.plotter.show_bounds(
                    grid="back",          # ← CRUCIAL
                    location="outer",    # ← CRUCIAL
                    ticks="both",
                    all_edges=True,
                    xtitle="X",
                    ytitle="Y",
                    ztitle="Z",
                    font_size=12
                )

            # Trièdre visuel (optionnel)
                self.plotter.add_axes()

            # Caméra stable
                self.plotter.reset_camera()

            except Exception as e:
                self.statusBar().showMessage(f"❌ Error while updating mesh: {e}")


        def add_magnetization_vectors(self, axes_angles):
            """ Add magnetization vectors to surface nodes using optimized glyphs.
            """
            try:
                # Get surface nodes
                surface_nodes = get_surface_nodes(self.mesh_object)
                self.statusBar().showMessage(f"✓ Found {len(surface_nodes)} surface nodes")
            
            # Prepare lists for batch processing
                positions = []
                vectors = []
                vector_scale = self.vector_scale_spinbox.value()
                self.statusBar().showMessage(f"Vector scale: {vector_scale}")
            
            # Collect all positions and vectors
                for node_idx in surface_nodes:
                    if node_idx in self.magnetization_data:
                        node_pos = self.original_points[node_idx]
                        m_vec = self.magnetization_data[node_idx]
                        positions.append(node_pos)
                        vectors.append(m_vec)
            
                if not positions:
                    self.statusBar().showMessage("❌ No magnetization data found for surface nodes!")
                    return
            
                self.satusBar().showMessage(f"✓ Found magnetization data for {len(positions)} nodes")
            
            # Convert to numpy arrays for batch rotation
                positions = np.array(positions)
                vectors = np.array(vectors)
            
            # Apply rotations in batch
                rotated_positions = apply_sequential_quaternion_rotations(positions, axes_angles)
                rotated_vectors = apply_sequential_quaternion_rotations(vectors, axes_angles)
            
            # Scale vectors for visualization
                scaled_vectors = rotated_vectors * vector_scale
            
            # Calculate colors based on z-component
                z_components = rotated_vectors[:, 2]
                up_count = np.sum(z_components > 0.5)
                down_count = np.sum(z_components < -0.5)
                inplane_count = len(z_components) - up_count - down_count
                self.statusBar().showMessage(f"Magnetization distribution - Up: {up_count}, Down: {down_count}, In-plane: {inplane_count}")
            
            # Create a PolyData object with points and vectors
                vector_poly = pv.PolyData(rotated_positions)
                vector_poly['vectors'] = scaled_vectors
                self.statusBar().showMessage(f"Creating glyphs with scale factor {vector_scale}")
            
            # Create arrows using glyphs 
                vector_scale = self.vector_scale_spinbox.value()
                arrows = vector_poly.glyph(
                    orient='vectors',
                    scale=False,
                    factor=vector_scale,  # TEST
                    geom=pv.Arrow(tip_length=0.25, tip_radius=0.1, shaft_radius=0.05)
                )
            
            # Add to plotter in black
                self.plotter.add_mesh(arrows, color='black', opacity=0.8, show_scalar_bar=False)
                self.statusBar().showMessage(f"✓ Magnetization vectors added successfully with {arrows.n_cells} arrows and {arrows.n_points} points ")
                    
            except Exception as e:
                self.statusBar().showMessage(f"❌ Error adding magnetization vectors: {e}")
                import traceback
                traceback.print_exc()

        def add_bounding_box(self, original_points, axes_angles):
            """
            Add a bounding box around the mesh using 8 corner nodes and 12 edges.
            """
            xmin, ymin, zmin = np.min(original_points, axis=0)
            xmax, ymax, zmax = np.max(original_points, axis=0)
        
            corners = np.array([
                [xmin, ymin, zmin],  # 0
                [xmax, ymin, zmin],  # 1
                [xmax, ymax, zmin],  # 2
                [xmin, ymax, zmin],  # 3
                [xmin, ymin, zmax],  # 4
                [xmax, ymin, zmax],  # 5
                [xmax, ymax, zmax],  # 6
                [xmin, ymax, zmax],  # 7
            ])
        
            rotated_corners = apply_sequential_quaternion_rotations(corners, axes_angles)
        
            edges_x = [[0, 1], [3, 2], [4, 5]]
            edges_y = [[1, 2], [0, 3], [4, 7]]
            edges_z = [[0, 4], [1, 5], [3, 7]]
            edges   = [[7, 6], [5, 6], [2, 6]]
        
            for edge in edges_x:
                line_points = np.array([rotated_corners[edge[0]], rotated_corners[edge[1]]])
                line = pv.Line(line_points[0], line_points[1])
                self.plotter.add_mesh(line, color="red", line_width=4)
        
            for edge in edges_y:
                line_points = np.array([rotated_corners[edge[0]], rotated_corners[edge[1]]])
                line = pv.Line(line_points[0], line_points[1])
                self.plotter.add_mesh(line, color="green", line_width=4)
        
            for edge in edges_z:
                line_points = np.array([rotated_corners[edge[0]], rotated_corners[edge[1]]])
                line = pv.Line(line_points[0], line_points[1])
                self.plotter.add_mesh(line, color="blue", line_width=4)

            for edge in edges:
                line_points = np.array([rotated_corners[edge[0]], rotated_corners[edge[1]]])
                line = pv.Line(line_points[0], line_points[1])
                self.plotter.add_mesh(line, color="black", line_width=2)

        def compute(self):
            """Save YAML configuration and launch pathIntegral executable """
            self.save_yaml_config()
            if self.outputFileName != "noneYet":
                self.statusBar().showMessage(f"✓ YAML file saved: {self.outputFileName}, launch ray-tracing computations ...")
                self.lastLog = open("lastLog.log","wb")
                self.lastErr = open("lastErr.log","wb")
                self.process = QProcess()
                self.process.readyReadStandardOutput.connect(self.handle_pathIntegral_stdout)
                self.process.readyReadStandardError.connect(self.handle_pathIntegral_stderr)
                self.process.finished.connect(self.process_finished)
                self.process.start("pathIntegral",[self.outputFileName])
            else:
                self.statusBar().showMessage("Error: .sol not yet selected.")

        def process_finished(self):
            self.statusBar().showMessage("✓ Computations done, .out and .png files saved, lastLog.log (over)written.")
            self.process = None
            self.lastLog.close()
            self.lastErr.close()

        def handle_pathIntegral_stdout(self):
            out = self.process.readAllStandardOutput()
            self.lastLog.write(out)

        def handle_pathIntegral_stderr(self):
            err = self.process.readAllStandardError()
            if err:
                self.statusBar().showMessage("Error while ray tracing.")
                self.lastErr.write(err)

        def quit_and_save(self):
            """Save YAML configuration before quitting"""
            try:
                self.save_yaml_config()
            except Exception as e:
                reply = QMessageBox.question(
                    self, 
                    'Error Saving', 
                    f"Error saving configuration: {e}\n\nDo you still want to quit?",
                    QMessageBox.Yes | QMessageBox.No,
                    QMessageBox.No
                )
                if reply == QMessageBox.No:
                    return
            self.close()
except:
    print("Error: PyQt5 module(s) not imported")
    sys.exit()

def get_params():
    import argparse
    description = 'pathIntegral GUI frontend'
    epilogue = '''
    lauch a graphic user interface as a front-end to pathIntegral command line executable
    save a yaml file from the inputs within the graphic user interface
    launch pathIntegral executable from GUI to compute .out and .png outputs
    raw view of the output png's in a basic viewer
    '''
    parser = argparse.ArgumentParser(description=description, epilog=epilogue, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument('ymlFileName',help='a yaml settings input file')
    parser.add_argument('--version',action='version',version= __version__,help='show the version number')
    args = parser.parse_args()
    return args

def main():
    '''
    launnch the parsing of the command line
    if some NVIDIA GPU is found change some environnment variables for VTK to benefit from GPU
    then launch the GUI if PYQt5 is usable else exit 
    '''
    args = get_params()
    display = os.environ.get('DISPLAY') #might not run correctly on WayLand, see WAYLAND_DISPLAY environment variable
    if ((display == "") or (display is None)):
        print("Error: no display.")
        sys.exit()
    else:
        if has_nvidia_gpu():
            os.environ["__NV_PRIME_RENDER_OFFLOAD"] = "1"
            os.environ["__GLX_VENDOR_LIBRARY_NAME"] = "nvidia"
        else:
            print("Warning: no NVIDIA GPU detected.")

        try:
            from PyQt5.QtWidgets import QApplication
            app = QApplication(sys.argv)
            window = CombinedInterface(args.ymlFileName)
            window.show()
            sys.exit(app.exec_())
        finally:
            sys.exit()

__version__ = '0.2.0'
if __name__ == "__main__":
    main()
