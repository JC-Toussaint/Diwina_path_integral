def load_sol_file(filename):
    """
    Load magnetization vectors from a .sol file.
    Returns a dictionary: node_index -> (mx, my, mz)
    """
    magnetization = {}
    
    try:
        with open(filename, 'r') as f:
            for line in f:
                line = line.strip()
                # Skip comments and empty lines
                if line.startswith('#') or not line:
                    continue
                
                # Parse data lines
                parts = line.split()
                if len(parts) >= 4:
                    try:
                        idx = int(parts[0])
                        mx = float(parts[1])
                        my = float(parts[2])
                        mz = float(parts[3])
                        magnetization[idx] = np.array([mx, my, mz])
                    except (ValueError, IndexError):
                        continue
        
        return magnetization
    except Exception as e:
        raise RuntimeError(f"❌ Error loading .sol file '{filename}': {e}")

def get_surface_nodes(mesh):
    """
    Extract surface nodes from the mesh.
    Returns a set of node indices that are on the surface (triangular elements).
    """
    surface_nodes = set()
    
    for cell_block in mesh.cells:
        if cell_block.type == "triangle":
            # Add all nodes from triangular elements
            for tri in cell_block.data:
                surface_nodes.update(tri)
    
    return surface_nodes

def get_region_elements(mesh):
    """
    Return a dictionary mapping region name -> list of element descriptions.
    Each element description is a dict:
      {
        "cell_type": "triangle" / "tetra" / ...,
        "block_index": i,            # index of the cell block in mesh.cells
        "local_element_index": j,    # element index inside its cell block
        "global_element_index": g,   # element index counting across all blocks
        "nodes": array([...], dtype=int)  # node indices for that element
      }

    Requires mesh.field_data to map names -> [physical_id, dim].
    Uses mesh.cell_data to find the physical tag per element (common key is "gmsh:physical").
    """
    if not hasattr(mesh, "cells"):
        raise ValueError("❌ mesh has no attribute 'cells'")

    # 1) build mapping physical_id -> region_name using mesh.field_data
    id_to_name = {}
    for name, arr in mesh.field_data.items():
        try:
            phys_id = int(np.asarray(arr).flatten()[0])
        except Exception:
            continue
        id_to_name[phys_id] = name

    # 2) find the appropriate key in mesh.cell_data that holds physical tags
    phys_key = None
    if hasattr(mesh, "cell_data") and mesh.cell_data:
        for k in mesh.cell_data.keys():
            if k == "gmsh:physical":
                phys_key = k
                break
        if phys_key is None:
            for k in mesh.cell_data.keys():
                if "physical" in k.lower():
                    phys_key = k
                    break

    if phys_key is None:
        raise ValueError("No physical tags found in mesh.cell_data. Look for key 'gmsh:physical' or similar.")

    # 3) iterate cell blocks and attach elements to regions
    regions = {}
    global_idx = 0
    phys_tags_list = mesh.cell_data[phys_key]
    if len(phys_tags_list) != len(mesh.cells):
        raise ValueError("❌ Mismatch between number of cell blocks and number of cell_data arrays for key "
                         f"'{phys_key}' (found {len(phys_tags_list)} vs {len(mesh.cells)}).")

    for block_index, (cell_block, phys_tags) in enumerate(zip(mesh.cells, phys_tags_list)):
        cell_type = cell_block.type
        connectivity = np.asarray(cell_block.data, dtype=int)
        phys_tags = np.asarray(phys_tags, dtype=int).flatten()

        if connectivity.shape[0] != phys_tags.shape[0]:
            raise ValueError(f"❌ Number of elements in cell block {block_index} ({connectivity.shape[0]}) "
                             f"does not match number of physical tags ({phys_tags.shape[0]}).")

        for local_idx in range(connectivity.shape[0]):
            phys_id = int(phys_tags[local_idx])
            region_name = id_to_name.get(phys_id, f"phys_{phys_id}")
            elem = {
                "cell_type": cell_type,
                "block_index": block_index,
                "local_element_index": local_idx,
                "global_element_index": global_idx,
                "nodes": connectivity[local_idx].tolist()
            }
            regions.setdefault(region_name, []).append(elem)
            global_idx += 1

    return regions


def load_mesh(filename):
    """
    Load a mesh from a file using meshio.
    Returns a string message, surface node indices, point coordinates and triangular connectivity.
    Raises an error if the file does not exist or contains no triangles.
    """
    if not os.path.isfile(filename):
        raise FileNotFoundError(f"❌ The file '{filename}' does not exist.")
    try:
        import meshio
        mesh = meshio.read(filename)
        strMessage = f"✓ mesh file '{filename}' loaded, "
        for cell_block, cell_data in zip(mesh.cells, mesh.cell_data["gmsh:physical"]):
            cell_type = cell_block.type
            for region_name, (region_id, dim) in mesh.field_data.items():
                element_indices = np.where(cell_data == region_id)[0]

        regions = get_region_elements(mesh)
        points = mesh.points[:, :3]
        triangles = []
        for cell_block in mesh.cells:
            if cell_block.type == "triangle":
                triangles.append(cell_block.data)

        if not triangles:
            strMessage += f"✗ No triangles found in mesh '{filename}'."
            raise ValueError(f"❌ No triangles found in mesh '{filename}'.")

        triangles = np.vstack(triangles)
        strMessage += str(len(triangles)) + " triangles"
        surface_nodes = get_surface_nodes(mesh)

        return strMessage, surface_nodes, points, triangles

    except Exception as e:
        raise RuntimeError(f"❌ Error while loading mesh '{filename}': {e}")

def normalize(v):
    ''' return normalized v except if v=0 return (1,0,0) '''
    norm = np.linalg.norm(v)
    return v / norm if norm != 0 else np.array([1.0, 0.0, 0.0])

def apply_sequential_quaternion_rotations(points, axes_angles):
    ''' apply successive rotations to point list stored in points, in place '''
    rotated_points = points.copy()
    rotation = R.identity()
    for axis, angle in axes_angles:
        axis = normalize(np.array(axis))
        r = R.from_rotvec(np.deg2rad(angle) * axis)
        rotation = r * rotation
    return rotation.apply(rotated_points)

def create_pyvista_mesh(points, triangles):
    ''' return pyvista triangles '''
    faces = np.hstack([np.full((triangles.shape[0], 1), 3), triangles]).astype(np.int32)
    return pv.PolyData(points, faces)

def clean_yaml_content(content: str) -> str:
    ''' reformat content string to yaml friendly string '''
    lines = content.split('\n')
    cleaned_lines = [line.replace('\t', '  ') for line in lines]
    return '\n'.join(cleaned_lines)

def load_yaml_from_file(filename: str) -> Dict[str, Any]:
    '''
    return a status message string and yaml from input file as a dictionary
    '''
    strMessage = ""
    try:
        with open(filename, 'r', encoding='utf-8') as file:
            content = file.read()
        cleaned_content = clean_yaml_content(content)
        config = yaml.safe_load(cleaned_content)
        missingStuffs, bool_ok = check_input(config)
        if not bool_ok:
            strMessage = f"Missing inputs or errors in some inputs of the yaml file '{filename}':\n\t" + str(missingStuffs)
            print(strMessage)
            sys.exit()
        return strMessage, config
    except FileNotFoundError:
        strMessage = f"✗ File '{filename}' not found"
        return strMessage,None
    except Exception as e:
        strMessage = f"✗ Error reading file: {e}"
        return strMessage,None

def check_input(yaml_config):
    """
    check that dictionary built from yaml input file contains appropriate keys
    Warning: does not check if all volume_regions has their Js,lbp,lbm keys
    """
    missingStuffs = []
    checkSum = 0

    if 'initial_magnetization' in yaml_config:
        checkSum += 1
    else:
        missingStuffs.append("initial_magnetization")
    if 'rotations' in yaml_config:
        checkSum += 1
        rot = yaml_config['rotations']
        if 'angle1' in rot:
            checkSum += 1
        else:
            missingStuffs.append("angle1")
        if ('axe1' in rot) and (len(rot['axe1']) == 3):
            checkSum += 1
        else:
            missingStuffs.append("axe1")
        if 'angle2' in rot:
            checkSum += 1
        else:
            missingStuffs.append("angle2")
        if ('axe2' in rot) and (len(rot['axe2']) == 3):
            checkSum += 1
        else:
            missingStuffs.append("axe2")
    else:
        missingStuffs.append("rotations")
    if 'filled' in yaml_config:
        checkSum += 1
    else:
        missingStuffs.append("filled")
    if 'sensor' in yaml_config:
        checkSum += 1
        det = yaml_config['sensor']
        if 'zoom' in det:
            checkSum += 1
        else:
            missingStuffs.append("zoom")
        if 'meshSize' in det:
            checkSum += 1
        else:
            missingsStuffs.append("meshSize")
    else:
        missingStuffs.append("sensor")
    check_bool = (checkSum == 10)

    return missingStuffs, check_bool

def yaml_dump(data, context=None, prefix=""):
    """
    Simple YAML serializer. Should be appropriate for the YAML documents
    handled by this script, and probably not much more.

    Serialize a Python object in YAML. Collections are serialized in
    block style, except for lists of numbers, which are serialized in
    flow style.
    """

    def is_inline(data):
        """
        Should this piece of data be serialized inline (in flow style)?
        """
        if isinstance(data, list):
            return all(isinstance(value, (int, float)) for value in data)
        return not isinstance(data, dict)

    text = ""
    indent = "  "
    if isinstance(data, dict):
        for i, (key, value) in enumerate(data.items()):
            if is_inline(value):
                separator = " "
            else:
                separator = "\n"
            if i > 0 or context != 'list':
                text += prefix
            text += f"{key}:{separator}{yaml_dump(value, 'object', prefix + indent)}"
    elif isinstance(data, list):
        if is_inline(data):
            return text + "[" + ", ".join(map(str, data)) + "]\n"
        for i, value in enumerate(data):
            text += f"{prefix}- {yaml_dump(value, 'list', prefix + indent)}"
    elif isinstance(data, bool):
        text += f"{str(data).lower()}\n"
    elif data is None:
        text += "null\n"
    else:
        text += f"{str(data)}\n"
    return text

def save_yaml_file(data: dict, filename: str):
    ''' save dictionary data into a yaml text file '''
    with open(filename, 'w') as f:
        f.write("# this file was generated by fmit-calculator\n\n")
        f.write(yaml_dump(data))

