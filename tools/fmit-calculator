            missingStuffs.append("relative_size")
        if 'pixel_size' in det:
            checkSum += 1
        else:
            missingsStuffs.append("pixel_size")
    else:
        missingStuffs.append("sensor")
    check_bool = (checkSum == 10)

    return missingStuffs, check_bool

def yaml_dump(data, context=None, prefix=""):
    """
    Simple YAML serializer. Should be appropriate for the YAML documents
    handled by this script, and probably not much more.

    Serialize a Python object in YAML. Collections are serialized in
    block style, except for lists of numbers, which are serialized in
    flow style.
    """

    def is_inline(data):
        """
        Should this piece of data be serialized inline (in flow style)?
        """
        if isinstance(data, list):
            return all(isinstance(value, (int, float)) for value in data)
        return not isinstance(data, dict)

    text = ""
    indent = "  "
    if isinstance(data, dict):
        for i, (key, value) in enumerate(data.items()):
            if is_inline(value):
                separator = " "
            else:
                separator = "\n"
            if i > 0 or context != 'list':
                text += prefix
            text += f"{key}:{separator}{yaml_dump(value, 'object', prefix + indent)}"
    elif isinstance(data, list):
        if is_inline(data):
            return text + "[" + ", ".join(map(str, data)) + "]\n"
        for i, value in enumerate(data):
            text += f"{prefix}- {yaml_dump(value, 'list', prefix + indent)}"
    elif isinstance(data, bool):
        text += f"{str(data).lower()}\n"
    elif data is None:
        text += "null\n"
    else:
        text += f"{str(data)}\n"
    return text

def save_yaml_file(data: dict, filename: str):
    ''' save dictionary data into a yaml text file '''
    with open(filename, 'w') as f:
        f.write("# this file was generated by fmit-calculator\n\n")
        f.write(yaml_dump(data))

def chunk_parser(fileName):
    ''' parse some of the chunks of the png fileName, returns a dictionary and a string '''
    import png
    img = png.Reader(fileName)
    comments = ""
    someMetaData = {
        "Pixel width": "unknown",
        "Pixel height": "unknown",
        "Pixel unit": "unknown",
        "Value min": "unknown",
        "Value max": "unknown",
        "Value unit": "unknown"
    }
    for balise in img.chunks():
        chunk_type = balise[0].decode('ascii')
        match chunk_type:
            case 'IHDR':
                # http://www.libpng.org/pub/png/spec/1.2/PNG-Chunks.html
                width = int.from_bytes(balise[1][0:4],byteorder='big')
                height = int.from_bytes(balise[1][4:8],byteorder='big')
                bitDepth = int.from_bytes(balise[1][8:9],byteorder='big')
                comments += " (" + str(width) + "x" + str(height) + " px, " + str(bitDepth) + " bit, Grayscale)"
            case 'pCAL':
                # https://w3c.github.io/png/extensions/Overview.html#C.pCAL
                idx = balise[1].find(b'\x00')
                calibrationName = balise[1][0:idx].decode('ascii')
                idx += 1
                originalZero = int.from_bytes(balise[1][idx:idx+4],byteorder='big')
                idx += 4
                originalMax = int.from_bytes(balise[1][idx:idx+4],byteorder='big')
                idx += 4
                equationType = int.from_bytes(balise[1][idx:idx+1],byteorder='big')
                idx += 1
                numberOfParameters = int.from_bytes(balise[1][idx:idx+1],byteorder='big')
                idx += 1
                idx2 = balise[1][idx:].find(b'\x00')
                someMetaData["Value unit"] = balise[1][idx:idx+idx2].decode('ascii')
                if (numberOfParameters == 2) and (equationType == 0) and (originalZero == 0) and (originalMax == 65535):
                    idx = balise[1].rfind(b'\x00')
                    prm1 = float(balise[1][idx+1:].decode('ascii'))
                    idx2 = balise[1][0:idx].rfind(b'\x00')
                    prm0 = float(balise[1][idx2+1:idx].decode('ascii'))
                    someMetaData["Value min"] = prm0
                    someMetaData["Value max"] = prm0 + prm1
                else:
                    print("cannot handle calibration function" + calibrationName)
            case 'sCAL':
                # https://w3c.github.io/png/extensions/Overview.html#C.sCAL
                sCAL_unit = int.from_bytes(balise[1][0:1],byteorder='big')
                match sCAL_unit:
                    case 1: #meter
                        str_unit = "m"
                    case 2: #radian
                        str_unit = "rad"
                    case _: #undefined
                        str_unit = "arbitrary units"
                someMetaData["Pixel unit"] = str_unit
                idx = balise[1].find(b'\x00')
                someMetaData["Pixel width"] = balise[1][1:idx].decode('ascii')
                idx += 1
                someMetaData["Pixel height"] = balise[1][idx:].decode('ascii')
    return someMetaData, comments

def metadataFromPngFile(fileName):
    ''' return some of the png metadata in a string '''
    metaData, comments = chunk_parser(fileName)
    str_metadata = comments + ", min: " + str(metaData['Value min'])
    str_metadata += ", max: " + str(metaData['Value max'])
    str_metadata += ", px width: " + metaData['Pixel width']
    str_metadata += ", px height: " + metaData['Pixel height']
    return str_metadata

