class ZoomSynchronizer(QObject):
    """Gestionnaire centralisé pour synchroniser les zooms"""
    zoom_changed = pyqtSignal(float, object)
    
    def __init__(self):
        super().__init__() 
        self.viewers = []
        self._updating = False
    
    def register_viewer(self, viewer):
        self.viewers.append(viewer) 
        viewer.zoom_applied.connect(self.on_zoom_changed)
    
    def on_zoom_changed(self, factor, sender):
        if self._updating: return
        self._updating = True
        try:
            for viewer in self.viewers:
                if viewer != sender:
                    viewer.apply_zoom_from_sync(factor) 
        finally:
            self._updating = False

class PanSynchronizer(QObject):
    """Gestionnaire centralisé pour synchroniser la position absolue (centre de vue)"""
    pan_changed = pyqtSignal(float, float, object)

    def __init__(self):
        super().__init__() 
        self.viewers = []
        self._updating = False

    def register_viewer(self, viewer):
        self.viewers.append(viewer) 
        viewer.pan_applied.connect(self.on_pan_changed)

    def on_pan_changed(self, rel_x, rel_y, sender):
        if self._updating: return
        self._updating = True
        try:
            for viewer in self.viewers:
                if viewer != sender:
                    viewer.apply_pan_from_sync(rel_x, rel_y) 
        finally:
            self._updating = False

class AxisWidget(QLabel):
    def __init__(self, orientation='horizontal', parent=None):
        super().__init__(parent)
        self.orientation = orientation
        self.min_coord = 0
        self.max_coord = 100 
        if orientation == 'horizontal':
            self.setFixedHeight(20)
        else:
            self.setFixedWidth(50)
        
    def update_range(self, min_coord, max_coord):
        self.min_coord = min_coord
        self.max_coord = max_coord
        self.update()
        
    def paintEvent(self, event):
        painter = QPainter(self) 
        painter.setRenderHint(QPainter.Antialiasing)
        painter.setPen(QPen(Qt.black, 1))
        painter.setFont(QFont("Arial", 9))
        
        rect = self.rect()
        if self.orientation == 'horizontal':
            y_pos = rect.height() - 1
            painter.drawLine(0, y_pos, rect.width(), y_pos) 
            range_coord = self.max_coord - self.min_coord
            if range_coord > 0:
                n_ticks = 11 
                tick_values = np.linspace(self.min_coord, self.max_coord, n_ticks) 
                for i, value in enumerate(tick_values):
                    x_pos = int(i * rect.width() / (n_ticks - 1))
                    painter.drawLine(x_pos, y_pos, x_pos, y_pos - 3) 
                    text = f"{int(value)}"
                    text_rect = painter.fontMetrics().boundingRect(text)
                    painter.drawText(x_pos - text_rect.width() // 2, y_pos - 5, text) 
        else:
            x_pos = rect.width() - 1
            painter.drawLine(x_pos, 0, x_pos, rect.height()) 
            range_coord = self.max_coord - self.min_coord 
            if range_coord > 0:
                n_ticks = 11
                tick_values = np.linspace(self.min_coord, self.max_coord, n_ticks)
                for i, value in enumerate(tick_values):
                    y_pos = int(i * rect.height() / (n_ticks - 1)) 
                    painter.drawLine(x_pos, y_pos, x_pos - 3, y_pos) 
                    text = f"{int(value)}"
                    text_rect = painter.fontMetrics().boundingRect(text)
                    painter.drawText(x_pos - text_rect.width() - 5, y_pos + text_rect.height() // 2, text) 

class ImageViewer(QGraphicsView):
    view_changed = pyqtSignal(float, float, float, float)
    zoom_applied = pyqtSignal(float, object)
    pan_applied = pyqtSignal(float, float, object) # center_x_rel, center_y_rel, sender

    def __init__(self, image_path):
        super().__init__()
        self.setScene(QGraphicsScene(self))
        self.pixmap = QPixmap(image_path) 
        self.pixmap_item = QGraphicsPixmapItem(self.pixmap)
        self.scene().addItem(self.pixmap_item) 

        self.setDragMode(QGraphicsView.ScrollHandDrag)
        self.setTransformationAnchor(QGraphicsView.AnchorUnderMouse)
        self.setResizeAnchor(QGraphicsView.AnchorUnderMouse)
        self.setSceneRect(QRectF(self.pixmap.rect()))
        self.fitInView(self.sceneRect(), Qt.KeepAspectRatio)

        self._sync_updating = False

        # On connecte les barres de défilement pour synchroniser tout mouvement
        self.horizontalScrollBar().valueChanged.connect(self._handle_scroll)
        self.verticalScrollBar().valueChanged.connect(self._handle_scroll)

        self.emit_view_changed() 

    def _handle_scroll(self):
        """Calcule et émet le centre relatif de la vue lors d'un déplacement"""
        if self._sync_updating: return
        
        # Calcul du centre de la vue en coordonnées relatives (0.0 à 1.0)
        rect = self.viewport().rect()
        center_scene = self.mapToScene(rect.center())
        
        rel_x = center_scene.x() / self.pixmap.width()
        rel_y = center_scene.y() / self.pixmap.height()
        
        self.pan_applied.emit(rel_x, rel_y, self)
        self.emit_view_changed()

    def wheelEvent(self, event):
        if self._sync_updating: return
        zoom_in_factor = 1.1 # Plus rapide pour plus de confort
        zoom_out_factor = 1 / zoom_in_factor
        factor = zoom_in_factor if event.angleDelta().y() > 0 else zoom_out_factor
        
        self.scale(factor, factor) 
        self.zoom_applied.emit(factor, self)
        self.emit_view_changed()

    def apply_zoom_from_sync(self, factor):
        self._sync_updating = True
        try:
            self.scale(factor, factor) 
            self.emit_view_changed()
        finally:
            self._sync_updating = False

    def apply_pan_from_sync(self, rel_x, rel_y):
        """Recentre la vue sur les coordonnées relatives reçues"""
        self._sync_updating = True
        try:
            target_x = rel_x * self.pixmap.width()
            target_y = rel_y * self.pixmap.height()
            self.centerOn(target_x, target_y)
            self.emit_view_changed()
        finally:
            self._sync_updating = False

    def emit_view_changed(self):
        v_rect = self.viewport().rect()
        top_left = self.mapToScene(v_rect.topLeft())
        bottom_right = self.mapToScene(v_rect.bottomRight())
        
        img_w, img_h = self.pixmap.width(), self.pixmap.height()
        min_x = max(0, min(top_left.x(), img_w))
        max_x = max(0, min(bottom_right.x(), img_w))
        min_y = max(0, min(top_left.y(), img_h)) 
        max_y = max(0, min(bottom_right.y(), img_h)) 
        
        self.view_changed.emit(min_x, max_x, min_y, max_y)

def read_image_metadata(image_path):
    try:
        with Image.open(image_path) as img:
            metadata = img.text if hasattr(img, 'text') else {} 
            vmin, vmax, unit = None, None, None
            for key, value in metadata.items():
                if 'min' in key.lower():
                    m = re.search(r'[-+]?\d*\.?\d+', value)
                    if m: vmin = float(m.group()) 
                elif 'max' in key.lower():
                    m = re.search(r'[-+]?\d*\.?\d+', value)
                    if m: vmax = float(m.group()) 
                elif 'unit' in key.lower():
                    unit = value 
            return vmin, vmax, unit
    except: return None, None, None

def generate_colorbar_pixmap(cmap, vmin=0, vmax=1, unit=None):
    fig, ax = plt.subplots(figsize=(1.2, 4), dpi=100)
    ax.remove() 
    cbar_ax = fig.add_axes([0.1, 0.1, 0.2, 0.8])
    norm = plt.Normalize(vmin=vmin, vmax=vmax)
    cb = plt.colorbar(cm.ScalarMappable(norm=norm, cmap=cmap), cax=cbar_ax)
    cb.ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'{x:.2e}'))
    cb.ax.tick_params(labelsize=8) 
    if unit: cb.set_label(unit, rotation=90, labelpad=0) 
    fig.canvas.draw()
    buf = fig.canvas.buffer_rgba()
    w, h = fig.canvas.get_width_height()
    img_rgb = np.frombuffer(buf, dtype=np.uint8).reshape((h, w, 4))[:, :, :3].copy()
    plt.close(fig)
    image = QImage(img_rgb.tobytes(), w, h, w * 3, QImage.Format_RGB888) 
    return QPixmap.fromImage(image)

class ImageTab(QWidget):
    def __init__(self, image_path, cmap=None, vmin=None, vmax=None, unit=None):
        super().__init__()
        layout = QGridLayout()
        self.top_axis = AxisWidget('horizontal') 
        self.left_axis = AxisWidget('vertical')
        self.viewer = ImageViewer(image_path)
        self.viewer.view_changed.connect(self.update_axes) 
        
        colorbar_widget = None
        if cmap:
            vmin = vmin if vmin is not None else 0
            vmax = vmax if vmax is not None else 1 
            colorbar_pixmap = generate_colorbar_pixmap(cmap, vmin, vmax, unit)
            colorbar_widget = QLabel()
            colorbar_widget.setPixmap(colorbar_pixmap)
            colorbar_widget.setFixedWidth(140) 

        layout.addWidget(self.top_axis, 0, 1)
        layout.addWidget(self.left_axis, 1, 0)
        layout.addWidget(self.viewer, 1, 1)
        if colorbar_widget: layout.addWidget(colorbar_widget, 1, 2)
        
        layout.setColumnStretch(1, 1)
        layout.setRowStretch(1, 1)
        layout.setSpacing(0) 
        self.setLayout(layout)
    
    def update_axes(self, min_x, max_x, min_y, max_y):
        self.top_axis.update_range(min_x, max_x)
        self.left_axis.update_range(min_y, max_y)

class MainWindow(QMainWindow):
    def __init__(self, image_paths, colorbar_cmap_list, metadata_list, sim_name):
        super().__init__()
        self.setWindowTitle(f"FMIT Viewer — {sim_name}")
        self.zoom_sync = ZoomSynchronizer() 
        self.pan_sync = PanSynchronizer()
        self.tab_widget = QTabWidget()
        self.setCentralWidget(self.tab_widget)

        for idx, (path, cmap) in enumerate(zip(image_paths, colorbar_cmap_list)):
            vmin, vmax, unit = metadata_list[idx] if idx < len(metadata_list) else (None, None, None) 
            tab = ImageTab(path, cmap, vmin, vmax, unit)
            self.zoom_sync.register_viewer(tab.viewer) 
            self.pan_sync.register_viewer(tab.viewer)
            tab_name = path.split("/")[-1].replace(".png", "").replace(f"{sim_name}_", "")
            self.tab_widget.addTab(tab, tab_name) 

        self.resize(1100, 900)

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("SimFileName", help="Prefix of the simulation files") 
    args = parser.parse_args()
    sim_name = args.SimFileName

    app = QApplication(sys.argv)
    image_list = [f"{sim_name}_HOLO_PHASE.png", f"{sim_name}_MZ.png", 
                  f"{sim_name}_PATH_LENGTH.png", f"{sim_name}_STXM_XMCD.png"]
    gray_map = colormaps.get_cmap("gray")
    colorbar_cmap_list = [gray_map] * 4 

    metadata_list = [read_image_metadata(p) for p in image_list]
    window = MainWindow(image_list, colorbar_cmap_list, metadata_list, sim_name)
    window.show()
    sys.exit(app.exec_())

